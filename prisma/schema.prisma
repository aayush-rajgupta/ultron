generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthState {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatApproval {
  id        String   @id @default(cuid())
  jid       String   @unique
  approved  Boolean  @default(false)
  stopped   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  phoneNumber String   @id
  name        String
  tier        String   @default("stranger")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserHistory {
  id        String   @id @default(cuid())
  userId    String
  role      String   // Separation: 'user' (inbound), 'host' (manual outbound), 'bot' (automated outbound)
  content   String
  embedding Float[]
  createdAt DateTime @default(now())
}

